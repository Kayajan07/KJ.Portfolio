@model PortfolioItem

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Yeni Öğe Ekle</h5>
        <a class="btn btn-primary float-end" asp-action="Index">Geri</a>
    </div>
    <div class="card-body">

        <div class="mb-6">
            <label class="form-label" asp-for="Title"></label>
            <input class="form-control" asp-for="Title" type="text" disabled readonly />
        </div>

        <div class="mb-6">
            <label class="form-label" asp-for="Client"></label>
            <input class="form-control" asp-for="Client" type="text" disabled readonly />
        </div>

        <div class="mb-6">
            <label class="form-label" asp-for="ProjectYear"></label>
            <input class="form-control" asp-for="ProjectYear" type="date" disabled readonly />
        </div>

        <div class="mb-6">
            <label class="form-label" asp-for="Description"></label>
            <textarea class="form-control" asp-for="Description" disabled readonly></textarea>
        </div>

        <div class="mb-6">
            <label class="form-label" asp-for="CategoryId"></label>
            <input class="form-control" type="text" value="@Model.Category.Name" disabled readonly />
        </div>

        <div class="mb-6">
            <label class="form-label" asp-for="Tags"></label>
            @foreach (var item in Model.Tags)
            {
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" checked readonly disabled>

                    <label class="form-check-label">
                        @item.Name
                    </label>
                </div>
            }
        </div>

    </div>
</div>