@model PortfolioItem

@{
    SelectList? categories = ViewData["Categories"] != null
        ? ViewData["Categories"] as SelectList : null;

    List<PortfolioTag> tags = ViewData["Tags"] != null
        ? ViewData["Tags"] as List<PortfolioTag> : new List<PortfolioTag>();

    List<Guid> selectedTags = ViewData["SelectedTags"] != null
        ? ViewData["SelectedTags"] as List<Guid> : new List<Guid>();
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Yeni Öğe Ekle</h5>
        <a class="btn btn-primary float-end" asp-action="Index">Geri</a>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" style="color:red;"></div>

            <div class="mb-6">
                <label class="form-label" asp-for="Title"></label>
                <input class="form-control" asp-for="Title" type="text" />
                <span asp-validation-for="Title" style="color:red;"></span>
            </div>

            <div class="mb-6">
                <label class="form-label" asp-for="Client"></label>
                <input class="form-control" asp-for="Client" type="text" />
                <span asp-validation-for="Client" style="color:red;"></span>
            </div>

            <div class="mb-6">
                <label class="form-label" asp-for="ProjectYear"></label>
                <input class="form-control" asp-for="ProjectYear" type="date" />
                <span asp-validation-for="ProjectYear" style="color:red;"></span>
            </div>

            <div class="mb-6">
                <label class="form-label" asp-for="Description"></label>
                <textarea class="form-control" asp-for="Description"></textarea>
                <span asp-validation-for="Description" style="color:red;"></span>
            </div>

            <div class="mb-6">
                <label class="form-label" asp-for="CategoryId"></label>
                <select class="form-select" asp-for="CategoryId" asp-items="categories">
                </select>
                <span asp-validation-for="CategoryId" style="color:red;"></span>
            </div>

            <div class="mb-6">
                <label class="form-label" asp-for="Tags"></label>
                @foreach (var item in tags)
                {
                    <div class="form-check">
                        @if (selectedTags.Contains(item.Id))
                        {
                            <input class="form-check-input" type="checkbox"
                                   value="@item.Id" name="selectedTags" checked>
                        }
                        else
                        {
                            <input class="form-check-input" type="checkbox"
                                   value="@item.Id" name="selectedTags">
                        }

                        <label class="form-check-label">
                            @item.Name
                        </label>
                    </div>
                }
                <span asp-validation-for="Tags" style="color:red;"></span>
            </div>




            <button type="submit" class="btn btn-primary">Kaydet</button>
        </form>
    </div>
</div>