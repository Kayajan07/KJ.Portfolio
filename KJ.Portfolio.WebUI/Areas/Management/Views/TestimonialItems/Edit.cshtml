@model ExperienceListItem

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Yorum Düzenle</h5>
        <a class="btn btn-primary float-end" asp-action="Index">Geri</a>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" style="color:red;"></div>

            @Html.HiddenFor(x=>x.Id)
            @Html.HiddenFor(x=>x.HomePageId)
            @Html.HiddenFor(x=>x.ImageUrl)

            <div class="mb-6">
                <label class="form-label" asp-for="ImageUrl"></label>
                <input class="form-control" name="img" type="file" />
                <span asp-validation-for="ImageUrl" style="color:red;"></span>
            </div>

            <div class="mb-6">
                <label class="form-label" asp-for="FullName"></label>
                <input class="form-control" asp-for="FullName" type="text" />
                <span asp-validation-for="FullName" style="color:red;"></span>
            </div>

            <div class="mb-6">
                <label class="form-label" asp-for="Title"></label>
                <input class="form-control" asp-for="Title" type="text" />
                <span asp-validation-for="Title" style="color:red;"></span>
            </div>

            <div class="mb-6">
                <label class="form-label" asp-for="Comment"></label>
                <textarea class="form-control" asp-for="Comment"></textarea>
                <span asp-validation-for="Comment" style="color:red;"></span>
            </div>


            <button type="submit" class="btn btn-primary">Kaydet</button>
        </form>
    </div>
</div>