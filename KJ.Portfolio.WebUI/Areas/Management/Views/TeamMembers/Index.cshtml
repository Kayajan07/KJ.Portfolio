@model ICollection<Experience>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Ekip Üyeleri</h5>
        <a class="btn btn-primary float-end" asp-action="Create">Yeni Ekle</a>
    </div>
    <div class="card-body">

        <table class="table table-striped">
            <thead>
                <tr>
                    <th scope="col">Çalışan Adı</th>
                    <th scope="col">Çalışan Resmi</th>
                    <th scope="col">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FullName</td>
                        <td>
                            <img src="@item.ImageUrl" width="100" />
                        </td>
                        <td>
                            <a class="btn btn-info"
                                asp-action="Detail"
                                asp-route-id="@item.Id">Detay</a>

                            <a class="btn btn-warning"
                               asp-action="Edit"
                               asp-route-id="@item.Id">Düzenle</a>

                            <button class="btn btn-danger" onclick='Delete("@(item.Id)", this)'>Sil</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>


@section PageScripts{
        <script>
            function Delete(id, elem){
                $.ajax({
                    url: "/Management/Experiences/Delete/" + id,
                    method: "POST",
                    success: function(s){
                       if(s.success == true){
                           $(elem).closest("tr").remove();
                       }
                    },
                    error: function(){
                        alert("Bir sorun oluştu!");
                    }
                })
            }
        </script>
}
