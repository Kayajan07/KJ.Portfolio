@model Experience

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Ekip Üyesi Detay</h5>
        <a class="btn btn-primary float-end" asp-action="Index">Geri</a>
    </div>
    <div class="card-body">


        <div class="mb-6">
            <label class="form-label" asp-for="ImageUrl"></label>
            <img src="@Model.ImageUrl" width="200" />
            <span asp-validation-for="ImageUrl" style="color:red;"></span>
        </div>

        <div class="mb-6">
            <label class="form-label" asp-for="FullName"></label>
            <input class="form-control" asp-for="FullName" type="text" readonly disabled/>
            <span asp-validation-for="FullName" style="color:red;"></span>
        </div>

        <div class="mb-6">
            <label class="form-label" asp-for="Title"></label>
            <input class="form-control" asp-for="Title" type="text" readonly disabled />
            <span asp-validation-for="Title" style="color:red;"></span>
        </div>

        <div class="mb-6">
            <label class="form-label" asp-for="Description"></label>
            <textarea class="form-control" asp-for="Description" readonly disabled></textarea>
            <span asp-validation-for="Description" style="color:red;"></span>
        </div>

        <div class="mb-6">
            <label class="form-label" asp-for="SocialIconClass1"></label>
            <input class="form-control" asp-for="SocialIconClass1" type="text" readonly disabled />
            <span asp-validation-for="SocialIconClass1" style="color:red;"></span>
        </div>

        <div class="mb-6">
            <label class="form-label" asp-for="SocialUrl1"></label>
            <input class="form-control" asp-for="SocialUrl1" type="text" readonly disabled />
            <span asp-validation-for="SocialUrl1" style="color:red;"></span>
        </div>

        <div class="mb-6">
            <label class="form-label" asp-for="SocialIconClass2"></label>
            <input class="form-control" asp-for="SocialIconClass2" type="text" readonly disabled />
            <span asp-validation-for="SocialIconClass2" style="color:red;"></span>
        </div>

        <div class="mb-6">
            <label class="form-label" asp-for="SocialUrl2"></label>
            <input class="form-control" asp-for="SocialUrl2" type="text" readonly disabled />
            <span asp-validation-for="SocialUrl2" style="color:red;"></span>
        </div>

        <div class="mb-6">
            <label class="form-label" asp-for="SocialIconClass3"></label>
            <input class="form-control" asp-for="SocialIconClass3" type="text" readonly disabled />
            <span asp-validation-for="SocialIconClass3" style="color:red;"></span>
        </div>

        <div class="mb-6">
            <label class="form-label" asp-for="SocialUrl3"></label>
            <input class="form-control" asp-for="SocialUrl3" type="text" readonly disabled />
            <span asp-validation-for="SocialUrl3" style="color:red;"></span>
        </div>

    </div>
</div>